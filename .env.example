# GitHub auth mode: "device" comments as you, "app" comments as the GitHub App bot.
GITHUB_AUTH_MODE=device

# Simplest local setup: paste this in the UI or export it for dev scripts.
GITHUB_TOKEN=github_pat_xxx
GITHUB_OAUTH_CLIENT_ID=Ov23liQVEcCGHU1uxAGI

# GitHub App setup. Put the downloaded private key in .data/ and set the installation id after installing the app.
GITHUB_APP_ID=4158402
GITHUB_APP_SLUG=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=.data/github-app.private-key.pem

# Pi Agent / OpenRouter credentials.
OPENROUTER_API_KEY=
PI_AGENT_MODEL=deepseek/deepseek-v4-flash

# Postgres for durable agent activity. Docker exposes Postgres on host port 55432 to avoid common 5432 clashes.
DATABASE_URL=postgres://better_issues:better_issues@localhost:55432/better_issues

# Optional local cache path.
APP_DATA_DIR=.data
